# WhatsApp Agent — Environment Configuration

# LLM Provider (optional — falls back to keyword matching if not set)
LLM_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-haiku-latest

# Database — DB_PASSWORD is required (compose fails fast if unset)
DB_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql+psycopg2://crusty:change-me-strong-db-password@db:5432/crusty
REDIS_URL=redis://redis:6379/0

# Daily performance report recipient (E.164, e.g. +9199...). Empty = disabled.
DAILY_REPORT_RECIPIENT=
# Test phone for backend/test_system.py (E.164). Only needed to run the E2E test.
TEST_NUMBER=

# Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SECRET_KEY=change-me-to-random-32-char-string

# OpenWA Gateway (replaces Twilio)
# Deploy OpenWA via docker-compose — it auto-generates an API key on first run
# Check logs: docker logs wabot-openwa | grep "API Key"
OPENWA_BASE_URL=http://openwa:2785/api
OPENWA_API_KEY=
OPENWA_SESSION_ID=
# Optional shared secret. When set, /api/openwa/setup-session registers the
# webhook with this secret and the backend verifies the X-OpenWA-Signature HMAC
# on every inbound webhook (rejecting forged/unsigned requests).
OPENWA_WEBHOOK_SECRET=

# Deprecated (replaced by OpenWA):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=
